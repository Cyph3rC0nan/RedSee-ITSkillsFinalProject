# LLM Provider: openrouter | deepseek | ollama
LLM_PROVIDER=openrouter

# OpenRouter (recommended — one API key for all models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model: DeepSeek V4 Flash (fast, cost-effective)
LLM_MODEL=deepseek/deepseek-v4-flash

# Detailed model: Claude (for demo-day polished reports)
LLM_MODEL_DETAILED=anthropic/claude-sonnet-4-20250514

# Legacy: direct DeepSeek API
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Ollama fallback (local, no API key needed)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:7b

# Public Target Server (team lead shares this)
TARGET_URL=https://YOUR_TARGET_DOMAIN
TARGET_AUTH_USER=admin
TARGET_AUTH_PASS=password

# Live Wazuh SIEM (team lead shares this)
WAZUH_API_URL=https://WAZUH_HOST:55000
WAZUH_API_USER=admin
WAZUH_API_PASS=your-wazuh-password
WAZUH_DASHBOARD_URL=https://wazuh.YOUR_DOMAIN