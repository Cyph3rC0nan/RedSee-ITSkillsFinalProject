# LLM Provider: openrouter | deepseek | ollama
LLM_PROVIDER=openrouter

# OpenRouter (recommended — one API key for all models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model: DeepSeek V4 Flash (fast, cost-effective)
LLM_MODEL=deepseek/deepseek-v4-flash

# Detailed model: Claude (for demo-day polished reports)
LLM_MODEL_DETAILED=anthropic/claude-sonnet-4-20250514

# Legacy: direct DeepSeek API
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Ollama fallback (local, no API key needed)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:7b

# Public Target Server (team lead shares this)
TARGET_URL=https://YOUR_TARGET_DOMAIN
TARGET_AUTH_USER=admin
TARGET_AUTH_PASS=password

# Live Wazuh SIEM (team lead shares this)
WAZUH_API_URL=https://WAZUH_HOST:55000
WAZUH_API_USER=admin
WAZUH_API_PASS=your-wazuh-password
WAZUH_DASHBOARD_URL=https://wazuh.YOUR_DOMAIN

# RedSee Scope Gating (engine/scope.py) — authorized-testing scope, default-deny
REDSEE_TARGET_URL=http://localhost:3000          # Primary target for this engagement
REDSEE_ALLOWED_HOSTS=localhost,127.0.0.1          # Comma-separated exact hostnames (no wildcards/subdomains)
REDSEE_AUTHORIZED=false                           # Operator attestation — must be "true" before any active test runs
REDSEE_RATE_LIMIT=60                              # Max requests per minute against in-scope hosts

# RedSees Marketplace demo target (bash docker/demo-helper.sh marketplace) — themed
# Juice Shop (NODE_CONFIG_ENV=redsees) + demo-target/ reflected-XSS companion service,
# both fronted by demo-target/gateway/ on a single unified port :3000 (host
# networking). See docs/redsees_marketplace_vulns.txt for the ground-truth vuln map.
# Uncomment to point a scan at it instead of the block above:
# REDSEE_TARGET_URL=http://redsees.com:3000/market/
# REDSEE_ALLOWED_HOSTS=redsees.com

# RedSee BYOK LLM Layer (engine/llm.py) — bring your own OpenAI-compatible endpoint
REDSEE_LLM_BASE_URL=http://localhost:11434/v1     # OpenAI-compatible base URL (Ollama /v1, OpenAI, etc.)
REDSEE_LLM_MODEL=llama3.1                         # Model name as the endpoint expects it
REDSEE_LLM_API_KEY=                               # Optional — leave blank for Ollama (no Authorization header sent)
REDSEE_LLM_MAX_USD=1.00                           # Hard per-scan spend cap in USD — further calls raise once hit
REDSEE_LLM_PRICE_IN_PER_1K=0.0                     # $ per 1K input/prompt tokens (0.0 for free/local models)
REDSEE_LLM_PRICE_OUT_PER_1K=0.0                    # $ per 1K output/completion tokens (0.0 for free/local models)
REDSEE_LLM_TIMEOUT=120                            # Request timeout in seconds